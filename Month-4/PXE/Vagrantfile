Vagrant.configure("2") do |config|

  config.vm.define "pxeserver" do |server|
    server.vm.box      = "bento/ubuntu-22.04"
    server.vm.hostname = "pxeserver"

    # Forwarded port для доступа к Web-серверу с хоста
    server.vm.network "forwarded_port", guest: 80, host: 8080

    # Внутренняя сеть PXE (intnet) — для общения с pxeclient
    server.vm.network :private_network,
      ip: "10.0.0.20",
      virtualbox__intnet: "pxenet"

    # Дополнительный интерфейс для Ansible SSH
    server.vm.network :private_network, ip: "192.168.56.20", adapter: 3

    server.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
    end

    server.vm.provision "ansible" do |ansible|
      ansible.playbook         = "ansible/provision.yml"
      ansible.host_key_checking = false
      ansible.groups = {
        "pxeserver" => ["pxeserver"]
      }
    end
  end

  config.vm.define "pxeclient" do |client|
    # Vagrant требует vm.box для создания ВМ в VirtualBox.
    # Бокс используется только как заглушка — ВМ всегда грузится по PXE (boot1=net).
    # vagrant up pxeclient завершится с таймаутом SSH — это ожидаемо, ВМ остаётся запущенной.
    client.vm.box          = "bento/ubuntu-22.04"
    client.vm.boot_timeout = 30
    client.vm.hostname     = "pxeclient"

    client.vm.provider :virtualbox do |vb|
      vb.memory = "4096"
      vb.gui    = false  # headless — экран смотрим через RDP (VRDE)
      vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
      vb.customize [
        "modifyvm", :id,
        "--nic1", "intnet",
        "--intnet1", "pxenet",
        "--nic2", "none",
        "--boot1", "net",
        "--boot2", "none",
        "--boot3", "none",
        "--boot4", "none"
      ]
      # VRDE (VirtualBox RDP) — подключаться: rdp://localhost:3390
      vb.customize ["modifyvm", :id, "--vrde", "on"]
      vb.customize ["modifyvm", :id, "--vrdeport", "3390"]
      vb.customize ["modifyvm", :id, "--vrdeauthtype", "null"]
      vb.customize ["modifyvm", :id, "--vrde-property", "Security/Method=RDP"]
    end
    # pxeclient грузится по PXE — Ansible не нужен
  end

end
