{% raw %}
{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 0, "text": "DOWN" },
                "1": { "color": "green", "index": 1, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [ "lastNotNull" ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "pg_up",
          "legendFormat": "{{instance}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "PostgreSQL Exporter Up",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [ "lastNotNull" ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (instance) (pg_stat_database_numbackends{datname!~\"template0|template1\"})",
          "legendFormat": "{{instance}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Active Connections",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [ "lastNotNull" ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(pg_stat_database_xact_commit{datname!~\"template0|template1\"}[$__rate_interval])) + sum(rate(pg_stat_database_xact_rollback{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "TPS",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Transactions / sec",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_xact_commit{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} commits",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_xact_rollback{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} rollbacks",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Transactions",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_blks_hit{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} hits",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_blks_read{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} reads",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Buffer Cache Activity",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "time() - pg_postmaster_start_time_seconds",
          "legendFormat": "{{instance}} uptime",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Instance Uptime",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "{{ grafana_prometheus_uid }}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_tup_inserted{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} inserted",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_tup_updated{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} updated",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "sum by (instance) (rate(pg_stat_database_tup_deleted{datname!~\"template0|template1\"}[$__rate_interval]))",
          "legendFormat": "{{instance}} deleted",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Tuple Activity",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [ "postgres", "database", "exporter" ],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "PostgreSQL Overview",
  "uid": "postgres-overview",
  "version": 1,
  "weekStart": ""
}
{% endraw %}
