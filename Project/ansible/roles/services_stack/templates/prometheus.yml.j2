global:
  scrape_interval: 15s

{% if alertmanager_enabled | bool %}
alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

{% endif %}
rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - 127.0.0.1:9090

  - job_name: services-node
    static_configs:
      - targets:
          - node-exporter:9100

  - job_name: nextcloud-nodes
    static_configs:
      - targets:
{% for host in groups['nextcloud'] %}
          - {{ hostvars[host].nextcloud_dmz_ip }}:{{ node_exporter_port }}
{% endfor %}

  - job_name: postgres-nodes
    static_configs:
      - targets:
{% for host in groups['postgres'] %}
          - {{ hostvars[host].postgres_internal_ip }}:{{ node_exporter_port }}
{% endfor %}

  - job_name: postgres-exporters
    static_configs:
      - targets:
{% for host in groups['postgres'] %}
          - {{ hostvars[host].postgres_internal_ip }}:{{ postgres_exporter_port }}
{% endfor %}

  - job_name: observability-stack
    static_configs:
      - targets:
          - victorialogs:9428
          - grafana:3000
{% if alertmanager_enabled | bool %}
          - alertmanager:9093
{% endif %}
