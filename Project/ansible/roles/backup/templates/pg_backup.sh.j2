#!/bin/bash
set -e

DATE=$(date +%Y-%m-%d_%H-%M)
DUMP_FILE="{{ backup_dir }}/{{ postgres_db }}_${DATE}.sql.gz"

echo "[$(date)] Starting backup..."

sudo -u postgres pg_dump "{{ postgres_db }}" | gzip > "${DUMP_FILE}"

# Удалить бэкапы старше N дней
find {{ backup_dir }} -name "*.sql.gz" -mtime +{{ backup_keep_days }} -delete

echo "[$(date)] Backup saved: ${DUMP_FILE}"
