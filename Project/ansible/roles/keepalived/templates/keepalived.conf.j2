vrrp_script check_nextcloud {
    script "/usr/bin/curl -sf http://127.0.0.1/"
    interval 5
    fall    2
    rise    2
}

vrrp_instance VI_1 {
    state {{ keepalived_state }}
    interface {{ vip_interface }}
    virtual_router_id 51
    priority {{ keepalived_priority }}
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass nextcloud_vrrp
    }

    virtual_ipaddress {
        {{ vip_address }}
    }

    track_script {
        check_nextcloud
    }
}
