[Unit]
Description=Nextcloud Docker Compose stack
Requires=docker.service mnt-nextcloud.mount
After=docker.service network-online.target remote-fs.target mnt-nextcloud.mount
Wants=network-online.target remote-fs.target
ConditionPathIsMountPoint=/mnt/nextcloud

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/nextcloud
ExecStartPre=/usr/bin/mountpoint -q /mnt/nextcloud
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
