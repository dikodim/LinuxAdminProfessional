services:
  zabbix-db:
    image: postgres:15
    container_name: zabbix-db
    restart: always
    environment:
      POSTGRES_DB:       "{{ zabbix_db }}"
      POSTGRES_USER:     "{{ zabbix_user }}"
      POSTGRES_PASSWORD: "{{ zabbix_password }}"
    volumes:
      - /var/lib/zabbix/db:/var/lib/postgresql/data

  zabbix-server:
    image: zabbix/zabbix-server-pgsql:alpine-{{ zabbix_version }}-latest
    container_name: zabbix-server
    restart: always
    environment:
      DB_SERVER_HOST: zabbix-db
      POSTGRES_DB:       "{{ zabbix_db }}"
      POSTGRES_USER:     "{{ zabbix_user }}"
      POSTGRES_PASSWORD: "{{ zabbix_password }}"
    ports:
      - "10051:10051"
    depends_on:
      - zabbix-db

  zabbix-web:
    image: zabbix/zabbix-web-nginx-pgsql:alpine-{{ zabbix_version }}-latest
    container_name: zabbix-web
    restart: always
    environment:
      ZBX_SERVER_HOST: zabbix-server
      DB_SERVER_HOST:  zabbix-db
      POSTGRES_DB:       "{{ zabbix_db }}"
      POSTGRES_USER:     "{{ zabbix_user }}"
      POSTGRES_PASSWORD: "{{ zabbix_password }}"
      PHP_TZ: Europe/Moscow
    ports:
      - "8080:8080"
    depends_on:
      - zabbix-server
