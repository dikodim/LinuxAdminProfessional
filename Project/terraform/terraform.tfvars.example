project_name = "nextcloud-nsxv-lab"
environment  = "lab"

vcd = {
  user                 = "terraform@system"
  password             = "change-me"
  org                  = "my-org"
  vdc                  = "my-vdc"
  url                  = "https://vcd.example.local/api"
  max_retry_timeout    = 60
  allow_unverified_ssl = true
}

nsxv_edge = {
  edge_gateway_name    = "edge-nextcloud-lab"
  external_network     = "uplink-network"
  dmz_network_name     = "dmz-nextcloud"
  dmz_subnet_cidr      = "172.16.10.0/24"
  dmz_gateway_ip       = "172.16.10.1"
  internal_network_name = "internal-nextcloud"
  internal_subnet_cidr  = "172.16.20.0/24"
  internal_gateway_ip   = "172.16.20.1"
}

nextcloud_cluster = {
  cluster_name  = "nextcloud"
  node_count    = 2
  template_name = "debian-12-template"
  vm_cpu        = 2
  vm_memory_mb  = 4096
  dmz_ips       = ["172.16.10.11", "172.16.10.12"]
}

postgres_cluster = {
  cluster_name  = "postgres"
  template_name = "debian-12-template"
  vm_cpu        = 2
  vm_memory_mb  = 4096
  primary_ip    = "172.16.20.13"
  replica_ip    = "172.16.20.14"
}

monitoring_stack = {
  prometheus_vm_name = "prometheus-1"
  prometheus_ip      = "172.16.20.21"
  grafana_vm_name    = "grafana-1"
  grafana_ip         = "172.16.20.22"
}

backup_stack = {
  backup_vm_name   = "backup-1"
  backup_ip        = "172.16.20.31"
  repository_type  = "restic"
  pg_dump_schedule = "0 3 * * *"
}
