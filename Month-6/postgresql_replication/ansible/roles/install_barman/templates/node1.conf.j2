[node1]
description = "backup node1"
# SSH command to connect to node1
ssh_command = ssh {{ master_user }}@{{ master_ip }}
# Connection string for postgres server
conninfo = host={{ master_ip }} user={{ barman_user }} port=5432 dbname=postgres
retention_policy_mode = auto
retention_policy = RECOVERY WINDOW OF 7 days
wal_retention_policy = main
streaming_archiver = on
# Path to postgresql binaries on node1 (Ubuntu 22.04)
path_prefix = /usr/lib/postgresql/14/bin/
# Replication slot settings
create_slot = auto
slot_name = node1
# Streaming connection string
streaming_conninfo = host={{ master_ip }} user={{ barman_user }}
# Backup method
backup_method = postgres
archiver = on
